<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PokemonCardScanner.MAUI.ViewModels"
             xmlns:models="clr-namespace:PokemonCardScanner.Shared.Models;assembly=PokemonCardScanner.Shared"
             x:Class="PokemonCardScanner.MAUI.Pages.ResultPage"
             x:DataType="vm:ResultViewModel"
             Title="Card Result">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Card not found -->
            <VerticalStackLayout IsVisible="{Binding HasCard, Converter={StaticResource InvertBoolConverter}}"
                                 Spacing="12">
                <Label Text="Card Not Found"
                       FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#E3350D" />
                <Label Text="{Binding ScanResult.ErrorMessage}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Card found -->
            <VerticalStackLayout IsVisible="{Binding HasCard}" Spacing="12">

                <Image Source="{Binding Card.ImageUrl}"
                       HeightRequest="280" Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="{Binding Card.Name}"
                       FontSize="24" FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="{Binding Card.SetName, StringFormat='Set: {0}'}"
                       HorizontalOptions="Center" TextColor="Gray" />

                <Label Text="{Binding Card.CollectorNumber, StringFormat='#{0}'}"
                       HorizontalOptions="Center" TextColor="Gray" />

                <Label Text="{Binding Card.Rarity}"
                       HorizontalOptions="Center" TextColor="DarkSlateGray" />

                <!-- Prices -->
                <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

                <Label Text="TCGPlayer Prices"
                       FontSize="18" FontAttributes="Bold" />

                <Label Text="{Binding PriceSource}"
                       FontSize="12" TextColor="Gray" />

                <Label Text="No price data available for this card."
                       TextColor="Gray"
                       IsVisible="{Binding HasPrices, Converter={StaticResource InvertBoolConverter}}" />

                <CollectionView ItemsSource="{Binding Prices}"
                                IsVisible="{Binding HasPrices}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CardPrice">
                            <Border Stroke="LightGray" StrokeThickness="1"
                                    Padding="12" Margin="0,4">
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto">

                                    <Label Grid.Column="0"
                                           Text="{Binding Variant}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />

                                    <VerticalStackLayout Grid.Column="1" Margin="8,0">
                                        <Label Text="Low" FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                                        <Label Text="{Binding Low, StringFormat='${0:F2}'}"
                                               FontSize="13" HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Margin="8,0">
                                        <Label Text="Market" FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                                        <Label Text="{Binding Market, StringFormat='${0:F2}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#2A75BB" HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="3" Margin="8,0">
                                        <Label Text="High" FontSize="11" TextColor="Gray" HorizontalOptions="Center"/>
                                        <Label Text="{Binding High, StringFormat='${0:F2}'}"
                                               FontSize="13" HorizontalOptions="Center" />
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <Button Text="Scan Another Card"
                    Command="{Binding ScanAnotherCommand}"
                    BackgroundColor="#E3350D" TextColor="White"
                    CornerRadius="8" HeightRequest="52"
                    Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
