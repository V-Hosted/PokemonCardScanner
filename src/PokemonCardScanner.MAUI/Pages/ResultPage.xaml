<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PokemonCardScanner.MAUI.ViewModels"
             xmlns:models="clr-namespace:PokemonCardScanner.Shared.Models;assembly=PokemonCardScanner.Shared"
             x:Class="PokemonCardScanner.MAUI.Pages.ResultPage"
             x:DataType="vm:ResultViewModel"
             Title="Card Result">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Card not found -->
            <VerticalStackLayout IsVisible="{Binding HasCard, Converter={StaticResource InvertBoolConverter}}"
                                 Spacing="12">
                <Label Text="Card Not Found"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#E3350D" />
                <Label Text="{Binding ScanResult.ErrorMessage}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Card found -->
            <VerticalStackLayout IsVisible="{Binding HasCard}" Spacing="12">

                <Image Source="{Binding Card.ImageUrl}"
                       HeightRequest="280"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />

                <Label Text="{Binding Card.Name}"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="{Binding Card.SetName, StringFormat='Set: {0}'}"
                       HorizontalOptions="Center"
                       TextColor="Gray" />

                <Label Text="{Binding Card.CollectorNumber, StringFormat='#{0}'}"
                       HorizontalOptions="Center"
                       TextColor="Gray" />

                <Label Text="{Binding Card.Rarity}"
                       HorizontalOptions="Center"
                       TextColor="DarkSlateGray" />

                <!-- eBay prices -->
                <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

                <Label Text="Recent eBay Sales"
                       FontSize="18"
                       FontAttributes="Bold" />

                <Label Text="No sales data yet — eBay integration coming soon."
                       TextColor="Gray"
                       IsVisible="{Binding HasPrices, Converter={StaticResource InvertBoolConverter}}" />

                <VerticalStackLayout IsVisible="{Binding HasPrices}" Spacing="8">

                    <Label Text="{Binding PriceNote}" TextColor="Gray" FontSize="12" />

                    <CollectionView ItemsSource="{Binding RecentSales}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:EbaySalePrice">
                                <Border Stroke="LightGray" StrokeThickness="1" Padding="12" Margin="0,4">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="{Binding ListingTitle}"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Condition}" TextColor="Gray" FontSize="12" />
                                            <Label Text="{Binding SoldDate, StringFormat='Sold: {0:MMM d, yyyy}'}"
                                                   TextColor="Gray" FontSize="12" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Price, StringFormat='${0:F2}'}"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="#2A75BB"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{Binding AveragePrice, StringFormat='Average: ${0:F2}'}"
                           FontAttributes="Bold"
                           FontSize="16"
                           HorizontalOptions="End" />

                </VerticalStackLayout>

            </VerticalStackLayout>

            <Button Text="Scan Another Card"
                    Command="{Binding ScanAnotherCommand}"
                    BackgroundColor="#E3350D"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="52"
                    Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
