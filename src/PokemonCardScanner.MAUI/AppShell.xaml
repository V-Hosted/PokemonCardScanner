<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PokemonCardScanner.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:PokemonCardScanner.MAUI.Pages"
    Title="Pokemon Card Scanner">

    <ShellContent
        Title="Scan"
        ContentTemplate="{DataTemplate pages:ScanPage}"
        Route="ScanPage" />

    <ShellContent
        Title="Result"
        ContentTemplate="{DataTemplate pages:ResultPage}"
        Route="ResultPage"
        IsVisible="False" />

</Shell>
